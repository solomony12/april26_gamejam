  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "EA-88 is a US military site situated in the stillwoods right next to Stillwood
    national park. It also sometimes goes by the name \u201CBlackwall\u201D due to
    the imposing twenty foot tall black steel wall that surrounds the property\r\nThe
    site has been the source of endless conspiracy theories ever since its founding.\r\nIn
    1957 a controversial deal saw control of the land transferred from the US Parks
    service to the Department of Defense. In 1963 public records show that the Department
    of Defense built 2 warehouses on the land and gave it to the Defense Advanced
    Research Projects Agency (DARPA) for military research. Conspiracy theorists
    claim that DARPA has since contracted with the CIA to run human experimentation
    programs which they run on local immigrant children who are taken from their
    parents.\r\n\r\nWe spoke to one mother affected by these alleged kidnappings,
    Rodrirguez, who we will refer to by her last name only due to fears of retaliation
    for her reporting. Rodriguez, who lives near the site, says that one night two
    men identifying themselves only as EA-88 site staff came to her house and took
    her youngest daughter from her in the middle of the night. When she tried to
    stop the men, they claimed that if she said anything they\u2019d have her entire
    family deported.\r\n\r\nWe reached out to Michael Snepps, head of the EA-88 site.
    He explained that EA-88 runs materials and weapons experimentation and waved
    the claims off as \u201Cjust another crazed conspiracy.\u201D\r\nI\u2019m Melissa
    Jones with the MidMorning News."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 41762c4ab74a32b498636d9658fea25c, type: 2}
